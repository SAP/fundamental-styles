{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sap.github.io/fundamental-styles/schemas/component-frontmatter.schema.json",
  "title": "Component Documentation Frontmatter",
  "description": "JSON Schema for validating component documentation frontmatter in fundamental-styles",
  "type": "object",
  "required": [
    "component",
    "title",
    "category",
    "sourcePath",
    "generatedAt"
  ],
  "properties": {
    "component": {
      "type": "string",
      "description": "Component identifier (usually the selector)",
      "minLength": 0,
      "maxLength": 100,
      "examples": ["fd-button", "fd-table", "fd-dialog", ""]
    },
    "title": {
      "type": "string",
      "description": "Full component title with category path",
      "minLength": 3,
      "maxLength": 200,
      "examples": ["Components/Buttons/Button", "Layouts/Dynamic Page"]
    },
    "category": {
      "type": "string",
      "description": "Primary category of the component",
      "enum": [
        "Components",
        "Layouts",
        "Patterns",
        "BTP",
        "AI",
        "Deprecated",
        "Dev",
        "border",
        "border-radius",
        "container-queries",
        "elevation",
        "heading",
        "media-queries",
        "overflow",
        "padding",
        "page-title",
        "patterns",
        "reset",
        "text",
        "typography"
      ]
    },
    "selector": {
      "type": "string",
      "description": "CSS selector for the component",
      "pattern": "^(fd-[a-z][a-z0-9-]*)?$",
      "maxLength": 100,
      "examples": ["fd-button", "fd-table", ""]
    },
    "cssFile": {
      "type": "string",
      "description": "Main CSS file for the component",
      "maxLength": 100,
      "examples": ["button.css", "table.css", ""]
    },
    "sourcePath": {
      "type": "string",
      "description": "Path to the source story file",
      "pattern": "^packages/[^/]+/stories/.+\\.stories\\.js$",
      "minLength": 10,
      "maxLength": 500,
      "examples": ["packages/styles/stories/Components/button/button.stories.js"]
    },
    "tags": {
      "type": "array",
      "description": "Tags associated with the component",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "uniqueItems": true,
      "examples": [[], ["deprecated"], ["experimental", "beta"]]
    },
    "dependencies": {
      "type": "array",
      "description": "CSS dependencies (other components this component requires)",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "uniqueItems": true,
      "examples": [["button", "icon", "menu"]]
    },
    "relatedComponents": {
      "type": "array",
      "description": "Related components that work with this component",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "uniqueItems": true,
      "examples": [["button-split", "icon", "menu"]]
    },
    "stability": {
      "type": "string",
      "description": "Component stability status",
      "enum": ["stable", "deprecated", "experimental"],
      "examples": ["stable", "deprecated", "experimental"]
    },
    "generatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when documentation was generated",
      "format": "date-time",
      "examples": ["2026-05-28T16:36:10.302Z"]
    }
  },
  "additionalProperties": false
}
